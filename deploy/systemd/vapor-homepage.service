[Unit]
Description=Vapor Homepage Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=vapor
Group=vapor
WorkingDirectory=/opt/vapor-server-root
EnvironmentFile=/etc/vapor-server/homepage.env
ExecStart=/opt/vapor-server-root/target/release/vapor_homepage_server
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/var/lib/vapor-server/homepage

[Install]
WantedBy=multi-user.target
